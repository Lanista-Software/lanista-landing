{
  "name": "nuxt-app",
  "private": true,
  "scripts": {
    "build": "contentrain generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "contentrain generate && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "contentrain generate && nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cr:generate": "contentrain generate",
    "cr:watch": "contentrain generate --watch"
  },
  "dependencies": {
    "@contentrain/query": "^6.1.0",
    "@lui-ui/lui-nuxt": "^0.1.0",
    "@lui-ui/lui-tailwindcss": "^0.1.1",
    "@lui-ui/lui-vue": "^1.0.12",
    "@nuxt/eslint": "^0.5.7",
    "@nuxt/image": "^1.8.0",
    "@nuxt/scripts": "^0.9.5",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^8.5.3",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@tailwindcss/typography": "^0.5.15",
    "firebase": "^10.13.2",
    "nuxt": "^3.13.0",
    "remixicon": "^4.3.0",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.6.2",
    "contentrain": "^0.6.0"
  },
  "resolutions": {
    "jackspeak": "2.1.1"
  },
  "imports": {
    "#contentrain": {
      "types": "./.contentrain/client/index.d.ts",
      "import": "./.contentrain/client/index.mjs",
      "require": "./.contentrain/client/index.cjs",
      "default": "./.contentrain/client/index.mjs"
    },
    "#contentrain/*": {
      "types": "./.contentrain/client/*.d.ts",
      "import": "./.contentrain/client/*.mjs",
      "require": "./.contentrain/client/*.cjs",
      "default": "./.contentrain/client/*.mjs"
    }
  }
}
